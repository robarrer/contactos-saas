# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
WHATSAPP_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mi_token_de_verificacion
WHATSAPP_APP_SECRET=abc123def456
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789
META_GRAPH_VERSION=v23.0

# ─── LLM providers (fallback si la org no tiene los suyos) ───────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Seguridad interna ───────────────────────────────────────────────────────
# Secret compartido entre serverless functions (webhook → worker → agent-reply)
INTERNAL_API_SECRET=genera_un_valor_aleatorio_largo_aqui

# ─── Cron (Vercel) ───────────────────────────────────────────────────────────
CRON_SECRET=genera_otro_valor_aleatorio

# ─── App URL (opcional, Vercel lo resuelve automáticamente) ──────────────────
NEXT_PUBLIC_APP_URL=https://tudominio.vercel.app
